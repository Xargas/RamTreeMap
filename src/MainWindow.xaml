<Window x:Class="RamTreeMap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RamTreeMap"
        mc:Ignorable="d"
        Title="RAM TreeMap" Height="600" Width="1000"
        WindowState="Normal"
        Background="#F0F0F0"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="#2D2D2D" MouseDown="TitleBar_MouseDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <TextBlock Grid.Column="0" 
                       Text="RAM TreeMap" 
                       Foreground="White" 
                       FontSize="14"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>

            <!-- Refresh Button -->
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    Width="40"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontSize="16"
                    ToolTip="Refresh (F5)"
                    Click="RefreshButton_Click"
                    Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="⟳" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <Button x:Name="HideSmallProgramsButton"
                    Grid.Column="2"
                    Width="40"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontSize="14"
                    ToolTip="Hide small programs (&lt;1%)"
                    Click="HideSmallProgramsButton_Click"
                    Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="●" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <Button x:Name="ShowSystemMemoryButton"
                    Grid.Column="3"
                    Width="40"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontSize="14"
                    ToolTip="Show system memory (buffered &amp; free)"
                    Click="ShowSystemMemoryButton_Click"
                    Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="⊞" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <Button x:Name="MinimizeButton"
                    Grid.Column="4"
                    Width="40"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontSize="16"
                    Click="MinimizeButton_Click"
                    Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="−" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <Button x:Name="MaximizeButton"
                    Grid.Column="5"
                    Width="40"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontSize="16"
                    Click="MaximizeButton_Click"
                    Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="☐" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>

            <Button x:Name="CloseButton"
                    Grid.Column="6"
                    Width="40"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="White"
                    FontSize="16"
                    Click="CloseButton_Click"
                    Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="✕" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Canvas x:Name="TreemapCanvas" Background="White" SizeChanged="TreemapCanvas_SizeChanged"/>

            <Grid x:Name="LoadingOverlay" Background="#80000000" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse x:Name="ProgressCircle" 
                         Width="80" Height="80" 
                         StrokeThickness="4"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,20">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF0000" Offset="0.0"/>
                                <GradientStop Color="#FFFF00" Offset="0.3"/>
                                <GradientStop Color="#00FF00" Offset="0.5"/>
                                <GradientStop Color="#00FFFF" Offset="0.7"/>
                                <GradientStop Color="#0000FF" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                    </Ellipse>

                    <TextBlock Text="Loading..." 
                               Foreground="White" 
                               FontSize="16"
                               HorizontalAlignment="Center"
                               FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
